#!/bin/sh
set -eu

# shellcheck disable=SC2034
MODE=$(head -c1)

required_kib=$((5 * 1024 * 1024))
available_kib=$(df -k --output=avail /var 2>/dev/null | awk 'NR==2{print $1}')
if [ -z "${available_kib:-}" ] || [ "$available_kib" -lt "$required_kib" ]; then
    avail_gib=$(( ${available_kib:-0} / 1024 / 1024 ))
    printf 'ERROR: Insufficient free disk space on /var (%s GiB available, 5 GiB minimum).\n' "$avail_gib"
    printf 'ERROR: Juju/K8s need disk for snaps & containers. Free up space and retry.\n'
    exit 1
fi

if [ ! -x /snap/bin/juju ]; then
    printf '[2/9] Installing Juju snap...\n'
    snap install juju >&2 2>&1
fi

if [ ! -x /snap/bin/k8s ]; then
    printf '[3/9] Installing Canonical K8s...\n'
    snap install k8s --classic >&2 2>&1
fi

if ! /snap/bin/k8s status >/dev/null 2>&1; then
    printf '[4/9] Bootstrapping Canonical K8s...\n'
    /snap/bin/k8s bootstrap >&2 2>&1
fi

printf '[5/9] Waiting for Canonical K8s to be ready...\n'
i=0
while [ "$i" -lt 60 ]; do
    if /snap/bin/k8s status --wait-ready --timeout 5 >/dev/null 2>&1; then
        break
    fi
    sleep 5
    i=$((i + 1))
done
if ! /snap/bin/k8s status 2>/dev/null | grep -qE "cluster status:[[:space:]]+ready[[:space:]]*$"; then
    printf 'ERROR: Canonical K8s did not become ready.\n'
    exit 1
fi

if ! /snap/bin/k8s status 2>/dev/null | grep -q "local-storage.*enabled"; then
    printf '[6/9] Enabling local storage...\n'
    /snap/bin/k8s enable local-storage >&2 2>&1
fi

printf '[7/9] Exporting kubeconfig...\n'
/snap/bin/k8s config > /run/juju-installer-k8s-kubeconfig
chmod 0640 /run/juju-installer-k8s-kubeconfig
chgrp lxd /run/juju-installer-k8s-kubeconfig

echo 1
