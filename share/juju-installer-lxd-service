#!/bin/sh
set -eu

# shellcheck disable=SC2034
MODE=$(head -c1)

required_kib=$((5 * 1024 * 1024))
available_kib=$(df -k --output=avail /var 2>/dev/null | awk 'NR==2{print $1}')
if [ -z "${available_kib:-}" ] || [ "$available_kib" -lt "$required_kib" ]; then
    avail_gib=$(( ${available_kib:-0} / 1024 / 1024 ))
    printf 'ERROR: Insufficient free disk space on /var (%s GiB available, 5 GiB minimum).\n' "$avail_gib"
    printf 'ERROR: Juju/LXD need disk for snaps & containers. Free up space and retry.\n'
    exit 1
fi

if [ ! -x /snap/bin/juju ]; then
    printf '[2/5] Installing Juju snap...\n'
    snap install juju >&2 2>&1
fi

if [ ! -x /snap/bin/lxd ]; then
    printf '[3/5] Installing LXD...\n'
    python3 -c 'import socket; s=socket.socket(socket.AF_UNIX); s.connect("/run/lxd-installer.socket"); s.send(b"x"); s.recv(1)' >&2 2>&1
    i=0
    while [ "$i" -lt 90 ]; do
        sleep 1
        [ -x /snap/bin/lxd ] && break
        i=$((i + 1))
    done
    if [ ! -x /snap/bin/lxd ]; then
        printf 'ERROR: LXD snap installation timed out.\n'
        exit 1
    fi
fi

if ! /snap/bin/lxc storage list --format csv 2>/dev/null | grep -q default; then
    printf '[3/5] Initializing LXD...\n'
    /snap/bin/lxd init --auto >&2 2>&1
fi

echo 1
